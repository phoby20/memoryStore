generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Memory {
  id        String   @id @default(cuid())
  category  String
  key       String
  value     String
  userId    String   @default("default")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, category])
  @@index([userId])
}

model ApiKey {
  id        String   @id @default(cuid())
  key       String   @unique
  userId    String
  name      String
  createdAt DateTime @default(now())

  @@index([key])
}
